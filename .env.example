# ============================================================
# ResearchAI — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your credentials.
# Never commit your .env file to version control.
# ============================================================

# ── Application ─────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ── IBM watsonx.ai Credentials ──────────────────────────────
# Get these from: https://cloud.ibm.com/iam/apikeys
# and your watsonx.ai project settings.
WATSONX_API_KEY=WgcI_fYa8bYFDVHcK2ClUiOsWCrlOm6rIjLoO48XZ1bm
WATSONX_PROJECT_ID=c4531892-d718-4d5b-8f0b-d2a32cf15c32
WATSONX_URL=https://au-syd.dai.cloud.ibm.com

# ── IBM Granite Model Selection ─────────────────────────────
# Recommended: ibm/granite-13b-instruct-v2
# Alternatives: ibm/granite-7b-instruct
GRANITE_MODEL_ID=ibm/granite-13b-instruct-v2
GRANITE_EMBEDDING_MODEL=ibm/slate-125m-english-rtrvr

# ── Generation Parameters ───────────────────────────────────
MAX_NEW_TOKENS=1024
TEMPERATURE=0.7
TOP_P=0.9
TOP_K=50
REPETITION_PENALTY=1.1

# ── Vector Store ─────────────────────────────────────────────
# Options: chromadb (default, recommended) | faiss
VECTOR_STORE_TYPE=chromadb
EMBEDDING_DIMENSION=768
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RESULTS=5

# ── External Search APIs ────────────────────────────────────
# Semantic Scholar API key (optional — improves rate limits)
# Get from: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# PubMed API key (optional — for higher throughput)
# Get from: https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=

# ── Performance ─────────────────────────────────────────────
SEARCH_RESULTS_LIMIT=20
REQUEST_TIMEOUT=30
MAX_PDF_SIZE_MB=50
